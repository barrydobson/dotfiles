# This is Git's per-user configuration file.
[user]
	name = Barry Dobson
	useConfigOnly = true
	signingKey = DF808E7FF90BF7D8
	email = barry.dobson@tote.co.uk
[push]
	followTags = true
[core]
	excludesfile = ~/.gitignore
	autocrlf = input
  trustctime = false
  editor = code --wait
[branch]
  autosetuprebase = always
[color]
  ui = true
[fetch]
	prune = true
[push]
  default = upstream
[diff]
  tool = vscode
	noprefix = true
[difftool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE
[merge]
  tool = vscode
[mergetool "vscode"]
  cmd = code --wait $MERGED
[url "git@github.com:"]
  insteadOf = https://github.com/
[credential]
  helper = osxkeychain
[commit]
	gpgsign = true
[gpg]
	program = /usr/local/bin/gpg
[url "https://root:_1eo3yEMqHdy7CnFywQ_@gitlab.tote.co.uk"]
	insteadOf = https://gitlab.tote.co.uk
[url "https://@github.com"]
	insteadOf = https://github.com
[alias]
	pt = !git tag -l | xargs git tag -d && git fetch -t
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[init]
	defaultBranch = master
