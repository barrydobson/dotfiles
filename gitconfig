[github]
	user = barrydobson

[user]
	name = Barry Dobson
	useConfigOnly = true
	signingKey = DF808E7FF90BF7D8
	email = barry.dobson@tote.co.uk

[url "git@github.com:thetote"]
	insteadOf = https://github.com/thetote

[url "git@github.com:barrydobson"]
	insteadOf = https://github.com/barrydobson

[url "git@github.com:"]
  pushInsteadOf = https://github.com/
  pushInsteadOf = git://github.com/

[push]
	default = upstream
	followTags = true

[core]
	excludesfile = ~/.gitignore
	autocrlf = input
  trustctime = false
	editor = code --wait
	pager = less -FRX

[branch]
  autosetupmerge = true
  autosetuprebase = local

[color]
  ui = auto

[color "diff"]
  plain = white dim
  meta = normal dim
  frag = blue bold
  old = red
  new = green
  whitespace = red reverse

[color "status"]
  header = normal dim
  added = green
  changed = yellow
  untracked = cyan

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[fetch]
	prune = true

[diff]
  tool = vscode
	noprefix = true

[difftool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE

[merge]
  tool = vscode

[mergetool "vscode"]
  cmd = code --wait $MERGED

[credential]
  helper = osxkeychain

[commit]
	gpgsign = true

[gpg]
	program = /usr/local/bin/gpg

[alias]
	pt = !git tag -l | xargs git tag -d && git fetch -t

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[init]
	defaultBranch = main
