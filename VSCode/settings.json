{
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "colorize.include": [
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.less",
    "**/*.styl",
    "**/*.ts"
  ],
  "debug.javascript.autoAttachFilter": "smart",
  "debug.javascript.autoAttachSmartPattern": [
    "${workspaceFolder}/**",
    "!**/node_modules/**",
    "**/$KNOWN_TOOLS$/**",
    "yarn"
  ],
  "diffEditor.ignoreTrimWhitespace": false,
  "docker.commands.build": "${containerCommand} build --pull --rm -f \"${dockerfile}\" -t ${tag} \"${context}\"",
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.codeActionsOnSave": {},
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.fontVariations": false,
  "editor.fontWeight": 400,
  "editor.letterSpacing": 0.5,
  "editor.lineHeight": 22,
  "editor.formatOnPaste": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlineSuggest.enabled": true,
  "editor.language.brackets": [],
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.cursorStyle": "line",
  "editor.cursorWidth": 3,
  "editor.cursorBlinking": "phase",
  "editor.unicodeHighlight.invisibleCharacters": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.gotmpl": "helm",
    "*.hcl": "terraform"
  },
  "files.eol": "\n",
  "git.closeDiffOnOperation": true,
  "git.confirmSync": false,
  "git.pruneOnFetch": true,
  "git.rebaseWhenSync": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false,
    "shellscript": true,
    "yaml": true
  },
  "gitlens.defaultGravatarsStyle": "wavatar",
  "gitlens.views.repositories.files.layout": "tree",
  "go.delveConfig": {
    "apiVersion": 2,
    "dlvLoadConfig": {
      "followPointers": true,
      "maxArrayValues": 64,
      "maxStringLen": 300,
      "maxStructFields": -1,
      "maxVariableRecurse": 1
    },
    "showGlobalVariables": false
  },
  "go.formatTool": "gofumpt",
  "go.lintFlags": [
    "--fast"
  ],
  "go.lintTool": "golangci-lint",
  "go.toolsEnvVars": {
    "GOPRIVATE": "github.com/thetote/*"
  },
  "go.toolsManagement.autoUpdate": true,
  "go.useLanguageServer": true,
  "gopls": {
    "ui.semanticTokens": true
  },
  "hadolint.cliOptions": [
    "--no-color"
  ],
  "http.proxySupport": "off",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "json.schemas": [],
  "redhat.telemetry.enabled": false,
  "rest-client.environmentVariables": {
    "$shared": {
      "circle-api": "ac07428597b5e82900ec059d99d666f3695f0b5c"
    }
  },
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.copyOnSelection": false,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1"
  },
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.fontSize": 11,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.macOptionClickForcesSelection": true,
  "terminal.integrated.profiles.osx": {
    "tmux": {
      "icon": "terminal-tmux",
      "path": "tmux"
    },
    "zsh": {
      "args": [
        "-l"
      ],
      "path": "zsh"
    }
  },
  "terraform.languageServer.enable": true,
  "vs-kubernetes": {
    "checkForMinikubeUpgrade": true,
    "imageBuildTool": "Docker",
    "logsDisplay": "webview",
    "vs-kubernetes.autoCleanupOnDebugTerminate": false,
    "vs-kubernetes.crd-code-completion": "enabled",
    "vs-kubernetes.draft-path": "",
    "vs-kubernetes.helm-path": "",
    "vs-kubernetes.knownKubeconfigs": [],
    "vs-kubernetes.kubeconfig": "",
    "vs-kubernetes.kubectl-path": "",
    "vs-kubernetes.kubectlVersioning": "user-provided",
    "vs-kubernetes.minikube-path": "",
    "vs-kubernetes.namespace": "",
    "vs-kubernetes.nodejs-autodetect-remote-root": true,
    "vs-kubernetes.nodejs-debug-port": 9229,
    "vs-kubernetes.nodejs-remote-root": "",
    "vs-kubernetes.outputFormat": "yaml"
  },
  "workbench.colorCustomizations": {
    "terminal.ansiBlack": "#003541",
    "terminal.ansiBlue": "#268bd2",
    "terminal.ansiBrightBlack": "#586e75",
    "terminal.ansiBrightBlue": "#839496",
    "terminal.ansiBrightCyan": "#93a1a1",
    "terminal.ansiBrightGreen": "#586e75",
    "terminal.ansiBrightMagenta": "#6c6ec6",
    "terminal.ansiBrightRed": "#cb4b16",
    "terminal.ansiBrightWhite": "#fdf6e3",
    "terminal.ansiBrightYellow": "#657b83",
    "terminal.ansiCyan": "#2aa198",
    "terminal.ansiGreen": "#859901",
    "terminal.ansiMagenta": "#d33682",
    "terminal.ansiRed": "#dc322f",
    "terminal.ansiWhite": "#eee8d5",
    "terminal.ansiYellow": "#b58901",
    "terminal.background": "#0d0d0e",
    "terminal.foreground": "#839496",
    "terminalCursor.background": "#003541",
    "terminalCursor.foreground": "#839496"
  },
  "workbench.colorTheme": "Cobalt2",
  "workbench.editor.untitled.hint": "hidden",
  "workbench.preferredDarkColorTheme": "One Dark Pro",
  "workbench.productIconTheme": "icons-octicons",
  "workbench.startupEditor": "none",
  // Custom tags for the parser to use
  "yaml.customTags": [],
  "yaml.format.bracketSpacing": false,
  // Enable/disable default YAML formatter (requires restart)
  "yaml.format.enable": false,
  "remote.SSH.remotePlatform": {
    "racing-platform-infrastructure.devpod": "linux"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.iconTheme": "file-icons",
  "terminal.external.osxExec": "hyper.app",
  "application.shellEnvironmentResolutionTimeout": 120
}